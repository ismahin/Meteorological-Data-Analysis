# Comma-separated frontend origins allowed to call the API.
# For Vercel, replace this with your production URL, for example:
# BACKEND_CORS_ORIGINS=https://your-project.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Runtime artifact paths inside the Docker image.
MODEL_DIR=/app/models/bias_correction
BMD_STATIONS_JSON=/app/data/processed/bmd_station_coordinates_35.json
BMD_TIMESERIES_DIR=/app/data/processed/bmd_stations_3hourly
NASA_STATION_TIMESERIES_DIR=/app/data/processed/nasa_station_data/3h_picked
OPERATIONAL_MODEL_PATH=/app/models/operational_forecast/model_bundle.joblib

# NASA operational forecasting and optional BMD SYNOP observations from OGIMET.
# All request/input timestamps are UTC. OGIMET getsynop begin/end values are sent as UTC.
NASA_HISTORY_DAYS=90
NASA_CACHE_TTL_SECONDS=3600
NASA_STALE_CACHE_SECONDS=86400
NASA_TIMEOUT_SECONDS=45
NASA_RETRIES=2
BMD_OGIMET_ENABLED=true
BMD_OGIMET_CACHE_TTL_SECONDS=600
BMD_OGIMET_TIMEOUT_SECONDS=20
BMD_OGIMET_RETRIES=1
